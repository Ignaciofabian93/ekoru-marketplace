// ─── Enums ───────────────────────────────────────────────────────────────────────

enum Language {
  ES
  EN
  FR
  PT
  DE
}

enum ProductSize {
  XS
  S
  M
  L
  XL
}

enum WeightUnit {
  KG
  LB
  OZ
  G
}

enum Badge {
  POPULAR
  DISCOUNTED
  WOMAN_OWNED
  BEST_SELLER
  TOP_RATED
  COMMUNITY_FAVORITE
  LIMITED_TIME_OFFER
  FLASH_SALE
  BEST_VALUE
  HANDMADE
  SUSTAINABLE
  SUPPORTS_CAUSE
  FAMILY_BUSINESS
  CHARITY_SUPPORT
  LIMITED_STOCK
  SEASONAL
  FREE_SHIPPING
  FOR_REPAIR
  REFURBISHED
  EXCHANGEABLE
  LAST_PRICE
  FOR_GIFT
  OPEN_TO_OFFERS
  OPEN_BOX
  CRUELTY_FREE
  DELIVERED_TO_HOME
  IN_HOUSE_PICKUP
  IN_MID_POINT_PICKUP
}

enum ProductCondition {
  NEW
  OPEN_BOX
  LIKE_NEW
  FAIR
  POOR
  FOR_PARTS
  REFURBISHED
}

enum AdvertisementType {
  HERO_BANNER
  CATEGORY_HIGHLIGHT
  PRODUCT_HIGHLIGHT
  FEED_AD_BANNER
  NEWSLETTER_SPOTLIGHT
  PROMOTIONAL_SEARCH
  SOCIAL_MEDIA_SPOTLIGHT
  MONTHLY_PACKAGE
}

// ─── Models ──────────────────────────────────────────────────────────────────────

model Department {
  id                 Int                     @id @default(autoincrement())
  isActive           Boolean                 @default(true)
  sortOrder          Int                     @default(0)
  featuredFrom       DateTime?
  featuredUntil      DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  departmentCategory DepartmentCategory[]
  translations       DepartmentTranslation[]

  @@index([id])
  @@index([isActive, sortOrder])
  @@index([featuredUntil])
}

model DepartmentTranslation {
  id              Int        @id @default(autoincrement())
  departmentId    Int
  language        Language
  name            String
  slug            String
  href            String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, language])
  @@unique([slug, language])
  @@index([language, departmentId])
  @@index([slug, language])
}

model DepartmentCategory {
  id                            Int                             @id @default(autoincrement())
  departmentId                  Int
  isActive                      Boolean                         @default(true)
  sortOrder                     Int                             @default(0)
  featuredFrom                  DateTime?
  featuredUntil                 DateTime?
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  department                    Department                      @relation(fields: [departmentId], references: [id])
  departmentCategoryTranslation DepartmentCategoryTranslation[]
  productCategory               ProductCategory[]

  @@index([departmentId])
  @@index([isActive, sortOrder])
  @@index([featuredUntil])
}

model DepartmentCategoryTranslation {
  id                   Int                @id @default(autoincrement())
  departmentCategoryId Int
  language             Language
  name                 String
  slug                 String
  href                 String?
  metaTitle            String?
  metaDescription      String?
  metaKeywords         String[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  departmentCategory   DepartmentCategory @relation(fields: [departmentCategoryId], references: [id], onDelete: Cascade)

  @@unique([departmentCategoryId, language])
  @@unique([slug, language])
  @@index([language, departmentCategoryId])
  @@index([slug, language])
}

model ProductCategory {
  id                         Int                          @id @default(autoincrement())
  departmentCategoryId       Int
  averageWeight              Float?                       @default(0.0)
  size                       ProductSize?                 @default(M)
  weightUnit                 WeightUnit?                  @default(KG)
  isActive                   Boolean                      @default(true)
  sortOrder                  Int                          @default(0)
  featuredFrom               DateTime?
  featuredUntil              DateTime?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  product                    Product[]
  departmentCategory         DepartmentCategory           @relation(fields: [departmentCategoryId], references: [id], onDelete: Cascade)
  materials                  ProductCategoryMaterial[]
  productCategoryTranslation ProductCategoryTranslation[]

  @@index([departmentCategoryId])
  @@index([featuredUntil])
}

model ProductCategoryTranslation {
  id                Int             @id @default(autoincrement())
  productCategoryId Int
  language          Language
  name              String
  slug              String
  keywords          String[]
  href              String?
  metaTitle         String?
  metaDescription   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  metaKeywords      String[]
  productCategory   ProductCategory @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)

  @@unique([productCategoryId, language])
  @@unique([slug, language])
  @@index([language])
  @@index([language, productCategoryId])
  @@index([slug, language])
}

model ProductCategoryMaterial {
  id                Int                    @id @default(autoincrement())
  productCategoryId Int
  materialTypeId    Int
  quantity          Float
  unit              String                 @default("percentage")
  isPrimary         Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  material          MaterialImpactEstimate @relation(fields: [materialTypeId], references: [id])
  productCategory   ProductCategory        @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)

  @@unique([productCategoryId, materialTypeId])
  @@index([productCategoryId])
  @@index([materialTypeId])
  @@index([isPrimary])
}

model Product {
  id                   Int                      @id @default(autoincrement())
  name                 String
  description          String
  color                String?
  images               String[]
  brand                String
  price                Int
  productCategoryId    Int
  badges               Badge[]
  interests            String[]
  condition            ProductCondition         @default(NEW)
  conditionDescription String?
  isActive             Boolean                  @default(true)
  isExchangeable       Boolean                  @default(false)
  sellerId             String
  viewCount            Int                      @default(0)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  deletedAt            DateTime?
  featuredFrom         DateTime?
  featuredUntil        DateTime?
  advertisement        Advertisement[]
  chat                 Chat[]
  likes                MarketplaceProductLike[]
  productCategory      ProductCategory          @relation(fields: [productCategoryId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([price])
  @@index([sellerId])
  @@index([sellerId, isActive])
  @@index([isExchangeable, isActive])
  @@index([deletedAt])
  @@index([viewCount(sort: Desc)])
  @@index([productCategoryId, isActive, createdAt(sort: Desc)])
  @@index([featuredUntil])
}

model Chat {
  id                             Int       @id @default(autoincrement())
  senderId                       String
  receiverId                     String
  productId                      Int?
  isExchange                     Boolean   @default(false)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt
  product                        Product?  @relation(fields: [productId], references: [id])
  message                        Message[]
}

model Message {
  id        Int      @id @default(autoincrement())
  chatId    Int
  senderId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chat      Chat     @relation(fields: [chatId], references: [id])
}

model MaterialImpactEstimate {
  id                      Int      @id @default(autoincrement())
  materialType            String   @unique
  estimatedCo2SavingsKG   Float
  estimatedWaterSavingsLT Float
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  productCategoryMaterials  ProductCategoryMaterial[]
  translations              MaterialImpactEstimateTranslation[]

  @@index([materialType])
}

model MaterialImpactEstimateTranslation {
  id                       Int      @id @default(autoincrement())
  materialImpactEstimateId Int
  language                 Language
  materialTypeTranslation  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materialImpactEstimate MaterialImpactEstimate @relation(fields: [materialImpactEstimateId], references: [id], onDelete: Cascade)

  @@unique([materialImpactEstimateId, language])
  @@index([language])
}

model WaterImpactMessage {
  id           Int                             @id @default(autoincrement())
  min          Float                           @default(0.0)
  max          Float                           @default(0.0)
  message1     String
  message2     String
  message3     String
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt
  translations WaterImpactMessageTranslation[]
}

model WaterImpactMessageTranslation {
  id                   Int                @id @default(autoincrement())
  waterImpactMessageId Int
  language             Language
  message1             String
  message2             String
  message3             String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  waterImpactMessage   WaterImpactMessage @relation(fields: [waterImpactMessageId], references: [id], onDelete: Cascade)

  @@unique([waterImpactMessageId, language])
  @@index([language])
}

model Co2ImpactMessage {
  id           Int                           @id @default(autoincrement())
  min          Float                         @default(0.0)
  max          Float                         @default(0.0)
  message1     String
  message2     String
  message3     String
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt
  translations Co2ImpactMessageTranslation[]
}

model Co2ImpactMessageTranslation {
  id                 Int              @id @default(autoincrement())
  co2ImpactMessageId Int
  language           Language
  message1           String
  message2           String
  message3           String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  co2ImpactMessage   Co2ImpactMessage @relation(fields: [co2ImpactMessageId], references: [id], onDelete: Cascade)

  @@unique([co2ImpactMessageId, language])
  @@index([language])
}

model Advertisement {
  id             Int               @id @default(autoincrement())
  adType         AdvertisementType
  price          Int
  content        String
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean           @default(true)
  sellerId       String
  productId      Int?
  storeProductId Int?
  serviceId      Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  product        Product?          @relation(fields: [productId], references: [id])

  @@index([sellerId])
  @@index([adType])
  @@index([isActive])
  @@index([startDate, endDate])
  @@index([productId])
  @@index([storeProductId])
  @@index([serviceId])
}

model MarketplaceProductLike {
  id        Int      @id @default(autoincrement())
  sellerId  String
  productId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sellerId])
  @@index([productId])
  @@index([sellerId])
  @@index([createdAt(sort: Desc)])
}

